---
// Flat, small-radius, text-forward tag. NOT a rounded "sticker" pill with offset shadow.
type Verdict = 'good' | 'caution' | 'avoid';
interface Props { verdict: Verdict; label?: string; }
const { verdict, label } = Astro.props as Props;
const DEFAULT_LABEL: Record<Verdict, string> = {
  good: 'Recommended',
  caution: 'Caution',
  avoid: 'Avoid',
};
const text = label ?? DEFAULT_LABEL[verdict];
---
<span class="verdict-badge" data-verdict={verdict}>
  <span class="verdict-badge__dot" aria-hidden="true"></span>{text}
</span>

<style>
  .verdict-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    border-radius: 2px;
    padding: 0.32rem 0.7rem;
    line-height: 1;
  }
  .verdict-badge__dot {
    width: 0.55em;
    height: 0.55em;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .verdict-badge[data-verdict="good"] {
    color: #fff;
    background: var(--color-verdict-good);
  }
  .verdict-badge[data-verdict="good"] .verdict-badge__dot { background: #fff; }
  .verdict-badge[data-verdict="caution"] {
    color: #fff;
    background: var(--color-verdict-caution);
  }
  .verdict-badge[data-verdict="caution"] .verdict-badge__dot { background: #fff; }
  .verdict-badge[data-verdict="avoid"] {
    color: #fff;
    background: var(--color-verdict-avoid);
  }
  .verdict-badge[data-verdict="avoid"] .verdict-badge__dot { background: #fff; }
</style>
