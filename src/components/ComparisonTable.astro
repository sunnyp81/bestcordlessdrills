---
// Side-by-side own-brand-vs-premium comparison, same instrument-panel visual
// language as SpecPanel. This is the site's core recurring content unit.
type Verdict = 'good' | 'caution' | 'avoid';
interface Column {
  heading: string;
  subheading?: string;
  verdict?: Verdict;
}
interface Row {
  label: string;
  values: string[];
}
interface Props {
  columns: Column[];
  rows: Row[];
  caption?: string;
}
const { columns, rows, caption } = Astro.props as Props;
---
<figure class="comparison-table">
  {caption && <figcaption class="comparison-table__caption">{caption}</figcaption>}
  <div class="comparison-table__scroll">
    <table>
      <thead>
        <tr>
          <th scope="col" class="comparison-table__row-head"></th>
          {columns.map((c) => (
            <th scope="col" data-verdict={c.verdict}>
              <span class="comparison-table__heading">{c.heading}</span>
              {c.subheading && <span class="comparison-table__subheading">{c.subheading}</span>}
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr>
            <th scope="row">{r.label}</th>
            {r.values.map((v) => <td class="figure">{v}</td>)}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</figure>

<style>
  .comparison-table {
    margin: 0;
    border: 1px solid var(--color-hairline);
    border-radius: 4px;
    overflow: hidden;
    background: var(--color-card);
  }
  .comparison-table__caption {
    padding: 0.75rem 1.1rem;
    font-size: 0.8rem;
    color: var(--color-steel-500);
    border-bottom: 1px solid var(--color-hairline);
    background: var(--color-paper);
  }
  .comparison-table__scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  thead th {
    background: var(--color-ink-900);
    color: #fff;
    text-align: left;
    padding: 0.85rem 1.1rem;
    font-family: var(--font-heading);
    font-weight: 600;
    border-top: 3px solid var(--color-steel-500);
    white-space: nowrap;
  }
  thead th[data-verdict="good"] { border-top-color: var(--color-verdict-good); }
  thead th[data-verdict="caution"] { border-top-color: var(--color-verdict-caution); }
  thead th[data-verdict="avoid"] { border-top-color: var(--color-verdict-avoid); }
  .comparison-table__row-head { background: var(--color-ink-950); }
  .comparison-table__heading {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .comparison-table__subheading {
    display: block;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.72rem;
    color: var(--color-steel-300);
    text-transform: none;
    margin-top: 0.15rem;
  }
  tbody th {
    text-align: left;
    padding: 0.7rem 1.1rem;
    font-weight: 600;
    color: var(--color-ink-950);
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-hairline);
    white-space: nowrap;
    transition: background-color 160ms cubic-bezier(0.2, 0, 0, 1);
  }
  tbody td {
    padding: 0.7rem 1.1rem;
    color: var(--color-ink-900);
    border-bottom: 1px solid var(--color-hairline);
    border-left: 1px solid var(--color-hairline);
    transition: background-color 160ms cubic-bezier(0.2, 0, 0, 1);
  }
  tbody tr:last-child th,
  tbody tr:last-child td {
    border-bottom: none;
  }
  tbody tr:nth-child(even) td {
    background: color-mix(in srgb, var(--color-paper) 60%, var(--color-card));
  }
  tbody tr:hover th,
  tbody tr:hover td {
    background: color-mix(in srgb, var(--color-amber-300) 14%, var(--color-card));
  }
</style>
