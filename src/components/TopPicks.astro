---
import VerdictBadge from './VerdictBadge.astro';

export interface Pick {
  rank: string;
  name: string;
  figure: string;
  unit?: string;
  price?: string;
  why: string;
  verdict: 'good' | 'caution' | 'avoid';
  verdictLabel: string;
  href: string;
  linkText?: string;
  featured?: boolean;
}
interface Props {
  heading: string;
  sub: string;
  picks: Pick[];
}
const { heading, sub, picks } = Astro.props as Props;
const cols = Math.min(Math.max(picks.length, 2), 4);
---
<section class="toppicks" aria-labelledby="tp-heading">
  <div class="toppicks__head">
    <h2 id="tp-heading" class="toppicks__title">{heading}</h2>
    <p class="toppicks__sub">{sub}</p>
  </div>
  <div class="toppicks__grid" style={`--tp-cols:${cols}`}>
    {picks.map((p) => (
      <a class:list={['tpcard', { 'tpcard--featured': p.featured }]} href={p.href}>
        <span class="tpcard__rank">{p.rank}</span>
        <span class="tpcard__name">{p.name}</span>
        <span class="tpcard__figure figure">{p.figure}{p.unit && <span class="tpcard__unit">{p.unit}</span>}</span>
        {p.price && <span class="tpcard__price figure">{p.price}</span>}
        <span class="tpcard__why">{p.why}</span>
        <span class="tpcard__foot"><VerdictBadge verdict={p.verdict} label={p.verdictLabel} /><span class="tpcard__link">{p.linkText ?? 'See the pick ↓'}</span></span>
      </a>
    ))}
  </div>
</section>

<style>
  /* Answer-first picks band: the immediate scannable answer, directly under the hero. */
  .toppicks {
    margin: 0 0 2.75rem;
  }
  .toppicks__head {
    margin-bottom: 1.15rem;
  }
  .toppicks__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.6rem;
    line-height: 1.1;
    color: var(--color-ink-950);
    margin: 0 0 0.4rem;
  }
  .toppicks__sub {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-steel-500);
    max-width: 42rem;
  }
  .toppicks__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .toppicks__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1000px) {
    .toppicks__grid { grid-template-columns: repeat(var(--tp-cols, 4), 1fr); }
  }
  .tpcard {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.15rem 1.2rem 1.2rem;
    border: 1px solid var(--color-hairline);
    border-radius: 6px;
    background: var(--color-card);
    text-decoration: none;
    transition-property: transform, border-color, box-shadow;
    transition-duration: 160ms;
    transition-timing-function: cubic-bezier(0.2, 0, 0, 1);
  }
  .tpcard:hover {
    transform: translateY(-2px);
    border-color: var(--color-amber-500);
    box-shadow: 0 12px 24px -14px rgba(22, 24, 28, 0.4);
  }
  .tpcard--featured {
    background: var(--color-ink-950);
    border-color: var(--color-ink-950);
    box-shadow: 0 12px 28px -12px rgba(22, 24, 28, 0.45);
  }
  .tpcard__rank {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-amber-900);
  }
  .tpcard--featured .tpcard__rank { color: var(--color-amber-300); }
  .tpcard__name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.02rem;
    line-height: 1.2;
    color: var(--color-ink-950);
  }
  .tpcard--featured .tpcard__name { color: #fff; }
  .tpcard__figure {
    font-size: 2.1rem;
    font-weight: 500;
    line-height: 1;
    color: var(--color-amber-900);
    margin-top: 0.1rem;
  }
  .tpcard--featured .tpcard__figure { color: var(--color-amber-300); }
  .tpcard__unit {
    font-size: 0.95rem;
    margin-left: 0.12rem;
  }
  .tpcard__price {
    font-size: 0.8rem;
    color: var(--color-steel-500);
  }
  .tpcard--featured .tpcard__price { color: var(--color-steel-300); }
  .tpcard__why {
    font-size: 0.86rem;
    line-height: 1.45;
    color: var(--color-ink-800);
    flex-grow: 1;
  }
  .tpcard--featured .tpcard__why { color: var(--color-steel-300); }
  .tpcard__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    margin-top: 0.35rem;
    flex-wrap: wrap;
  }
  .tpcard__link {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-amber-900);
    white-space: nowrap;
  }
  .tpcard--featured .tpcard__link { color: var(--color-amber-300); }
  .tpcard:hover .tpcard__link { text-decoration: underline; text-underline-offset: 2px; }
</style>
