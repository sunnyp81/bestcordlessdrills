---
// "The Spec Ledger" - instrument-plate spec panel with a verdict rail.
// Recurring layout signature used across product/comparison pages.
interface DrillSpec {
  name: string;
  torqueNm: number;
  voltage: number;
  weightKg: number;
  chuckSizeMm: number;
  priceGBP: number;
  warrantyYears: number;
  batteryPlatform: string;
}
type Verdict = 'good' | 'caution' | 'avoid';
interface Props {
  spec: DrillSpec;
  verdict: Verdict;
  verdictLabel?: string;
  image?: string;
}
const { spec, verdict, verdictLabel, image } = Astro.props as Props;
const DEFAULT_LABEL: Record<Verdict, string> = {
  good: 'Recommended',
  caution: 'Caution',
  avoid: 'Avoid',
};
const rows: { label: string; value: string }[] = [
  { label: 'Torque', value: `${spec.torqueNm} Nm` },
  { label: 'Voltage', value: `${spec.voltage} V` },
  { label: 'Weight', value: `${spec.weightKg} kg` },
  { label: 'Chuck size', value: `${spec.chuckSizeMm} mm` },
  { label: 'UK price', value: `£${spec.priceGBP.toFixed(2)}` },
  { label: 'Warranty', value: `${spec.warrantyYears} yr` },
  { label: 'Battery platform', value: spec.batteryPlatform },
];
---
<div class="spec-panel" data-verdict={verdict}>
  <div class="spec-panel__rail-top" aria-hidden="true"></div>
  <div class="spec-panel__body">
    <div class="spec-panel__name-row">
      {image && <img src={image} alt={spec.name} loading="lazy" decoding="async" width="56" height="56" class="spec-panel__image" />}
      <p class="spec-panel__name">{spec.name}</p>
    </div>
    <p class="spec-panel__headline">
      <span class="figure spec-panel__headline-value">{spec.torqueNm}<span class="spec-panel__headline-unit">Nm</span></span>
      <span class="spec-panel__headline-label">torque</span>
    </p>
    <dl class="spec-panel__grid">
      {rows.map((r) => (
        <div class="spec-panel__row">
          <dt>{r.label}</dt>
          <dd class="figure">{r.value}</dd>
        </div>
      ))}
    </dl>
  </div>
  <div class="spec-panel__rail" role="img" aria-label={`Verdict: ${verdictLabel ?? DEFAULT_LABEL[verdict]}`}>
    <span class="spec-panel__rail-label">{verdictLabel ?? DEFAULT_LABEL[verdict]}</span>
  </div>
</div>

<style>
  .spec-panel {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 34px;
    background: var(--color-ink-950);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 12px 28px -12px rgba(22, 24, 28, 0.35);
  }
  .spec-panel__rail-top {
    position: absolute;
    inset: 0 34px 0 0;
    background-image: radial-gradient(circle, rgba(154, 163, 173, 0.18) 1px, transparent 1px);
    background-size: 16px 16px;
    mask-image: linear-gradient(to bottom, black, transparent 85%);
    -webkit-mask-image: linear-gradient(to bottom, black, transparent 85%);
    pointer-events: none;
  }
  .spec-panel__body {
    position: relative;
    padding: 1.4rem 1.6rem 1.6rem;
  }
  .spec-panel__name-row {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: 0 0 1rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--color-ink-800);
  }
  .spec-panel__image {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    object-fit: contain;
    background: #fff;
    border-radius: 4px;
    padding: 0.25rem;
  }
  .spec-panel__name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.15rem;
    color: #fff;
    margin: 0;
  }
  .spec-panel__headline {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin: 0 0 1.15rem;
  }
  .spec-panel__headline-value {
    font-size: 2.5rem;
    font-weight: 500;
    line-height: 1;
    color: var(--color-amber-300);
  }
  .spec-panel__headline-unit {
    font-size: 1.1rem;
    margin-left: 0.15rem;
    color: var(--color-amber-500);
  }
  .spec-panel__headline-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-steel-300);
  }
  .spec-panel__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.15rem 1.5rem;
    margin: 0;
  }
  .spec-panel__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px dashed var(--color-ink-800);
  }
  .spec-panel__row dt {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-steel-300);
    font-family: var(--font-sans);
  }
  .spec-panel__row dd {
    margin: 0;
    font-weight: 500;
    color: var(--color-steel-300);
    font-size: 0.95rem;
  }
  .spec-panel__rail {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .spec-panel__rail-label {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.66rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: #fff;
    white-space: nowrap;
  }
  .spec-panel[data-verdict="good"] .spec-panel__rail { background: var(--color-verdict-good); }
  .spec-panel[data-verdict="caution"] .spec-panel__rail { background: var(--color-verdict-caution); }
  .spec-panel[data-verdict="avoid"] .spec-panel__rail { background: var(--color-verdict-avoid); }
</style>
