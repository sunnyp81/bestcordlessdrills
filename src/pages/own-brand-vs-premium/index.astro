  { name: 'Titan TTI1257COM 18V TXP Combi Drill', url: '/own-brand-vs-premium/#erbauer-titan', position: 2 },
  { name: 'Mac Allister MCD18-Li-2 18V Combi Drill', url: '/own-brand-vs-premium/#mac-allister', position: 3 },
  { name: 'Ozito PXBHS 18V Brushless Combi Drill', url: '/own-brand-vs-premium/#ozito', position: 4 },
  { name: 'Aldi Ferrex 20V Cordless Combi Drill', url: '/own-brand-vs-premium/#aldi-lidl', position: 5 },
  { name: 'Lidl Parkside PSBSAP 20-Li C3 Hammer Drill Driver', url: '/own-brand-vs-premium/#aldi-lidl', position: 6 },
  { name: 'Makita DHP484Z 18V LXT Brushless Combi Drill', url: '/own-brand-vs-premium/#makita-dewalt-bosch', position: 7 },
  { name: 'DeWalt DCD796N 18V XR Brushless Compact Combi Drill', url: '/own-brand-vs-premium/#makita-dewalt-bosch', position: 8 },
  { name: 'Bosch GSB 18V-55 Professional Combi Drill', url: '/own-brand-vs-premium/#makita-dewalt-bosch', position: 9 },
  { name: 'Milwaukee M18 BPD-402C Compact Combi Drill', url: '/own-brand-vs-premium/#milwaukee', position: 10 },
  { name: 'Ryobi R18PD3 18V ONE+ Combi Drill', url: '/own-brand-vs-premium/#ryobi', position: 11 },
];

const schema = [
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Own-Brand vs Premium', url: '/own-brand-vs-premium/' },
  ]),
  faqSchema(faqs),
  itemListSchema({
    name: 'Own-brand vs premium cordless drills compared',
    url: '/own-brand-vs-premium/',
    items: itemListItems,
  }),
];

const worthItPicks = [
  { rank: 'Fewer than 10× a year', name: 'Own-brand is fine', figure: '~£60-80', price: 'Titan, Mac Allister', why: 'Matches premium on torque for home jobs, with a flat 2-year guarantee and no registration step.', verdict: 'good' as const, verdictLabel: 'Good for occasional DIY', href: '#usage-threshold', linkText: 'See the threshold ↓' },
  { rank: '10+ times a year', name: 'Premium is worth it', figure: '~£65-150', price: 'Makita, DeWalt, Bosch', why: 'A registered 3-year warranty and a battery platform that fits dozens of other tools.', verdict: 'good' as const, verdictLabel: 'Worth it for regular use', href: '#usage-threshold', linkText: 'See the threshold ↓' },
];
---
<BaseLayout {title} {description} ogImage="/og/own-brand-vs-premium.png" {schema}>
  <div class="hero-band hero-band--page">
    <div class="hero-band__inner">
      <p class="hero-band__eyebrow">Independent &middot; UK &middot; Research-led</p>
      <h1 class="hero-band__title">Own-brand vs premium cordless drills: are retailer drills worth it?</h1>
      <p class="hero-band__lede">Erbauer, Titan and Ozito match Makita and DeWalt on torque and no-load speed for most home jobs. The real gap between own-brand and premium cordless drills is warranty terms and battery-platform lock-in, not raw drilling power.</p>
    </div>
  </div>
  <div class="page">
    <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Own-Brand vs Premium', url: '/own-brand-vs-premium/' }]} />

    <TopPicks
      heading="The verdict, at a glance"
      sub="Own-brand has closed the spec gap. Warranty terms and battery lock-in decide it, and both come down to how often you drill."
      picks={worthItPicks}
    />

    <div class="prose-drills">
      <p>An own-brand drill suits occasional DIY. A premium drill's registered warranty and shared battery platform earn back the higher price under regular or heavy use.</p>

      <Disclosure />

      <figure class="content-visual">
