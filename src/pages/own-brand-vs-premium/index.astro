import { breadcrumbSchema, faqSchema, itemListSchema } from '../../lib/schema';
import { buildAmazonLink, amazonSearchLink, AFFILIATE_REL } from '../../lib/affiliate';

const title = 'Own-Brand vs Premium Cordless Drills: Worth It?';
const description = 'Own-brand drills like Erbauer and Ozito match Makita and DeWalt on torque and price. Warranty terms and battery lock-in decide which is worth buying.';

const ownBrandColumns = [
  { heading: 'Erbauer', subheading: 'Screwfix', verdict: 'good' as const },
  { heading: 'Titan', subheading: 'Screwfix', verdict: 'good' as const },
  { heading: 'Mac Allister', subheading: 'B&Q', verdict: 'good' as const },
  { heading: 'Ozito', subheading: 'Independent retailers', verdict: 'caution' as const },
  { heading: 'Aldi / Lidl', subheading: 'Seasonal special-buys', verdict: 'caution' as const },
];
const ownBrandRows = [
  { label: 'UK price', values: ['£159.99', '£79.99', '£60 (was £80)', '~£75 bare tool', 'From £14.99 tool-only'] },
  { label: 'Torque', values: ['Not independently verified', '50 Nm', 'Not published', '40 Nm', 'Not published'] },
  { label: 'Warranty', values: ['1 yr standard', '2 yr, no registration', '2 yr, no registration', 'Claims up to 5 yr, verify terms', 'Not confirmed, check in store'] },
  { label: 'Battery platform', values: ['Erbauer EXT', 'Titan TXP', 'Mac Allister 18V', 'Ozito PXC', 'Own range only, sold separately'] },
];

const premiumColumns = [
  { heading: 'Makita', subheading: 'LXT', verdict: 'good' as const },
  { heading: 'DeWalt', subheading: 'XR', verdict: 'good' as const },
  { heading: 'Bosch', subheading: 'Professional', verdict: 'good' as const },
  { heading: 'Milwaukee', subheading: 'M18', verdict: 'good' as const },
  { heading: 'Ryobi', subheading: 'ONE+', verdict: 'caution' as const },
];
const premiumRows = [
  { label: 'UK price', values: ['£52.95 to £65 body-only', '£65.10 body-only, £109.99 kit', '£149.99 kit (was £199.99)', '£159.98 to £219.99', '£67.98 kit (was £84.98)'] },
  { label: 'Torque', values: ['65 Nm max', '70 Nm max', '55 Nm max', '60 Nm', '50 Nm'] },
  { label: 'Warranty', values: ['1 yr default, 3 yr if registered in 30 days', '1 yr default, 3 yr if registered in 30 days', '1 yr default, 3 yr tool/2 yr battery if registered', '1 yr default, 3 yr if registered', 'Not confirmed, historically 2 yr standard'] },
