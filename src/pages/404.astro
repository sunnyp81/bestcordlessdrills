---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Page Not Found - Best Cordless Drills UK';
const description = 'That page has moved or no longer exists. Start from our NODE hubs or buying guides.';
---
<BaseLayout {title} {description} noindex={true}>
  <article class="not-found">
    <p class="not-found__code">404</p>
    <h1 class="not-found__title">This page has moved or no longer exists</h1>
    <p class="not-found__lead">
      Head back to the homepage, or try one of the hubs below.
    </p>
    <div class="not-found__links">
      <a href="/own-brand-vs-premium/">Own-Brand vs Premium</a>
      <a href="/drill-vs-combi-vs-impact-driver/">Drill vs Combi vs Impact Driver</a>
      <a href="/battery-platforms-explained/">Battery Platforms Explained</a>
      <a href="/glossary/">Glossary</a>
      <a href="/best-budget/">Best Budget</a>
      <a href="/best-combi-drill/">Best Combi Drill</a>
    </div>
    <p class="not-found__back">Or head back to the <a href="/">homepage</a>.</p>
  </article>
</BaseLayout>

<style>
  .not-found {
    max-width: 42rem;
    margin: 0 auto;
    padding: 4.5rem 1.25rem;
    text-align: center;
  }
  .not-found__code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--color-amber-900);
    margin-bottom: 0.75rem;
  }
  .not-found__title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-ink-950);
    line-height: 1.2;
  }
  @media (min-width: 768px) {
    .not-found__title { font-size: 2.75rem; }
  }
  .not-found__lead {
    margin-top: 1rem;
    color: var(--color-ink-800);
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .not-found__links {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    text-align: left;
  }
  @media (min-width: 640px) {
    .not-found__links { grid-template-columns: 1fr 1fr; }
  }
  .not-found__links a {
    display: block;
    border: 1px solid var(--color-hairline);
    border-radius: 4px;
    padding: 0.9rem 1.1rem;
    color: var(--color-ink-950);
    font-weight: 600;
    background: var(--color-card);
    transition: border-color 160ms cubic-bezier(0.2, 0, 0, 1);
  }
  .not-found__links a:hover {
    border-color: var(--color-amber-900);
    color: var(--color-amber-900);
  }
  .not-found__back {
    margin-top: 2.5rem;
    color: var(--color-ink-800);
  }
  .not-found__back a {
    color: var(--color-amber-900);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
