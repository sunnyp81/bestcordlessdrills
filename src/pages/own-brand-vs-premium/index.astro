    q: 'How many times a year should I drill before buying a premium drill?',
    a: "Buy own-brand for jobs such as shelves, curtain rails and flatpack furniture if you drill fewer than about 10 times a year. Buy premium if you drill more often than that. The registered 3 year warranty and shared battery platform earn back the extra price under regular use.",
  },
];

const itemListItems = [
