---
// ASA/FTC affiliate disclosure - place near the top of every money page.
interface Props { compact?: boolean }
const { compact = false } = Astro.props as Props;
---
<aside
  class="disclosure"
  data-compact={compact ? 'true' : 'false'}
  role="note"
>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="disclosure__icon" aria-hidden="true">
    <circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
  </svg>
  <p>
    <strong>Affiliate disclosure:</strong> as an Amazon Associate we earn from qualifying purchases. It never affects our picks.
    <a href="/about/#how-we-research">How we research</a>.
  </p>
</aside>

<style>
  .disclosure {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    border: 1px solid var(--color-amber-300);
    background: color-mix(in srgb, var(--color-amber-300) 12%, var(--color-card));
    color: var(--color-ink-900);
    border-radius: 3px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin: 1rem 0;
  }
  .disclosure[data-compact="true"] {
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
  }
  .disclosure__icon {
    margin-top: 0.15rem;
    flex-shrink: 0;
    color: var(--color-amber-900);
  }
  .disclosure a {
    color: var(--color-amber-900);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 600;
  }
</style>
