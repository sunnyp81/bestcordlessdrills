        ))}
        <a href="/about/">
          <span class="explore-grid__label">About + how we research</span>
          <span class="explore-grid__blurb">Who writes this site and the four checks behind every verdict.</span>
        </a>
      </div>

      <FAQ faqs={displayFaqs} />
    </div>
  </div>
</BaseLayout>

