---
import { NODE_HUBS, BUYING_GUIDES, SITE } from '../lib/site';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="site-footer__grid">
    <div>
      <h3>Explore</h3>
      <ul>
        <li><a href="/">Home</a></li>
        {NODE_HUBS.map((h) => (<li><a href={`/${h.slug}/`}>{h.label}</a></li>))}
      </ul>
    </div>
    <div>
      <h3>Buying Guides</h3>
      <ul>
        {BUYING_GUIDES.map((g) => (<li><a href={`/${g.slug}/`}>{g.label}</a></li>))}
      </ul>
    </div>
    <div>
      <h3>{SITE.shortName}</h3>
      <ul>
        <li><a href="/about/">About + how we research</a></li>
        <li><a href="/about/#how-we-research">Our methodology</a></li>
      </ul>
    </div>
  </div>

  <div class="tick-divider" aria-hidden="true"></div>

  <div class="site-footer__bottom">
    <p class="site-footer__disclosure">
      As an Amazon Associate we earn from qualifying purchases.
      <a href="/about/#how-we-research">How we research</a>.
    </p>
    <p class="site-footer__meta">
      &copy; {year} {SITE.publisher}. Independent reviews.
      <span class="site-footer__reviewed">Last reviewed: pending content pass</span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink-950);
    color: var(--color-steel-300);
    margin-top: 4rem;
  }
  .site-footer__grid {
    max-width: 76rem;
    margin: 0 auto;
    padding: 3rem 1.25rem 2rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    font-size: 0.875rem;
  }
  @media (min-width: 768px) {
    .site-footer__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .site-footer__grid h3 {
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.85rem;
  }
  .site-footer__grid ul { display: flex; flex-direction: column; gap: 0.55rem; }
  .site-footer__grid a {
    color: var(--color-steel-300);
    transition: color 160ms cubic-bezier(0.2, 0, 0, 1);
  }
  .site-footer__grid a:hover { color: var(--color-amber-500); }
  .site-footer__bottom {
    max-width: 76rem;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.78rem;
    color: var(--color-steel-500);
  }
  .site-footer__disclosure a,
  .site-footer__meta a {
    color: var(--color-steel-300);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .site-footer__reviewed {
    display: inline-block;
    margin-left: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-steel-500);
  }
</style>
